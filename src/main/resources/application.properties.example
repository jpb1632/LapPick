spring.application.name=lappick
spring.config.import=optional:file:./config/application-secrets.properties

file.upload.dir=/path/to/upload/directory

# Thymeleaf
spring.thymeleaf.cache=false
spring.thymeleaf.prefix=classpath:/templates/thymeleaf/
spring.thymeleaf.suffix=.html

# DB
# log4jdbc
spring.datasource.url=jdbc:log4jdbc:oracle:thin:@//localhost:1521/XEPDB1
spring.datasource.driver-class-name=net.sf.log4jdbc.sql.jdbcapi.DriverSpy
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

# MyBatis
mybatis.type-aliases-package=lappick.domain
mybatis.configuration.map-underscore-to-camel-case=true
mybatis.mapper-locations=classpath*:/mappers/**/*.xml
mybatis.configuration.jdbc-type-for-null=VARCHAR

# Local mail sandbox (Mailpit)
spring.mail.host=127.0.0.1
spring.mail.port=1025
spring.mail.username=
spring.mail.password=
spring.mail.properties.mail.smtp.auth=false
spring.mail.properties.mail.smtp.starttls.enable=false
spring.mail.properties.mail.smtp.connectiontimeout=3000
spring.mail.properties.mail.smtp.timeout=3000
spring.mail.properties.mail.smtp.writetimeout=3000
app.mail.from=no-reply@lappick.local
app.mail.preview-enabled=false
app.mail.preview-url=http://127.0.0.1:8025

# File upload
spring.servlet.multipart.max-file-size=100MB
spring.servlet.multipart.max-request-size=100MB
spring.thymeleaf.encoding=UTF-8
server.servlet.encoding.charset=UTF-8
server.servlet.encoding.enabled=true
server.servlet.encoding.force=true

logging.level.lappick=INFO
logging.level.org.springframework.web.servlet.resource=INFO
logging.level.org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerMapping=INFO

# Transaction
spring.transaction.default-timeout=10
spring.transaction.rollback-on-commit-failure=true

# HikariCP
spring.datasource.hikari.maximum-pool-size=70
spring.datasource.hikari.minimum-idle=10
spring.datasource.hikari.connection-timeout=5000
spring.datasource.hikari.validation-timeout=3000
